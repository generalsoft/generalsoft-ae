---
import Layout from '../layouts/Layout.astro';
---
<Layout 
  title="Contact Generalsoft FZ-LLC | Software Company in Dubai, UAE"
  description="Contact Generalsoft FZ-LLC in Dubai, UAE for software development, AI solutions, and IT services. Call, email, or visit us."
  path="/contact/"
>
  <header>
    <nav>
      <a href="/" class="logo">
        <img width="48" src="/img/logo.webp" alt="GeneralSoft Logo"/>
        <span class="logo-text">Generalsoft<span class="logo-legal">FZ-LLC</span></span>
      </a>
      <span class="lang-switch"><a href="/ar/contact/">العربية</a></span>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li class="dropdown">
          <a href="#services" class="dropbtn">Services <span class="dropdown-arrow">▼</span></a>

          <div class="dropdown-content">
            <a href="/services/custom-software/">Custom Software Development</a>
            <a href="/services/education-training/">Education & Training</a>
            <a href="/services/ai-development/">AI Development</a>
            <a href="/services/systems-design/">Systems & Software Design</a>
            <a href="/services/cyber-security/">Cyber Security</a>
            <a href="/services/web-design/">Web & Network Design</a>
            <a href="/services/mobile-apps/">Mobile Applications</a>
            <a href="/services/electronic-systems/">Electronic Systems</a>
          </div>
        </li>
        <li><a href="/contact/">Contact Us</a></li>
        <li><a href="/#about">About Us</a></li>
      </ul>
    </nav>
  </header>

  <section class="contact-page-hero">
    <div class="container">
      <h1>Get In Touch</h1>
      <p>We'd love to hear from you. Let's discuss how we can help transform your business.</p>
    </div>
  </section>

  <section class="contact-page-content">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-container">
          <h2>Send Us a Message</h2>
          <form id="contactForm" class="contact-form" novalidate>
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone">
            </div>

            <div class="form-group">
              <label for="company">Company Name</label>
              <input type="text" id="company" name="company">
            </div>

            <div class="form-group">
              <label for="service">Service Required</label>
              <select id="service" name="service">
                <option value="">Select a service</option>
                <option value="Custom Software Development">Custom Software Development</option>
                <option value="Education & Training">Education & Training</option>
                <option value="AI Development">AI Development</option>
                <option value="Systems & Software Design">Systems & Software Design</option>
                <option value="Cyber Security">Cyber Security</option>
                <option value="Web & Network Design">Web & Network Design</option>
                <option value="Mobile Applications">Mobile Applications</option>
                <option value="Electronic Systems">Electronic Systems</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>

            <button type="submit" class="submit-btn">Send Message</button>
            <div id="formMessage" class="form-message"></div>
          </form>
        </div>

        <div class="contact-info-container">
          <h2>Contact Information</h2>

          <div class="info-item">
            <div class="info-icon">📧</div>
            <div class="info-content">
              <h3>Email</h3>
              <p>info@generalsoft.ae</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📞</div>
            <div class="info-content">
              <h3>Phone</h3>
              <p>+971.55.880.9863</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📍</div>
            <div class="info-content">
              <h3>Address</h3>
              <p>Ras Al Khaimah Economic Zone (RAKEZ)<br>Ras Al Khaimah, United Arab Emirates</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">🕐</div>
            <div class="info-content">
              <h3>Business Hours</h3>
              <p>Sunday - Thursday: 9:00 AM - 6:00 PM<br>Friday - Saturday: Closed</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initContactForm } from '../js/firebase-contact.js';
    initContactForm('contactForm', 'formMessage', {}, 'en');
  </script>
</Layout>
