---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Our Technology Partners | Generalsoft UAE"
  description="Generalsoft partners with global technology leaders like Microsoft, Google, Apple, IBM, Cisco, and Oracle to deliver world-class software and IoT solutions in the UAE."
  path="/partners/"
  image="/img/og-partners.jpg"
>
  <main>
    <section
      class="page-header"
      style="padding: 100px 0 50px; text-align: center; background: linear-gradient(135deg, #1a2a6c, #b21f1f, #fdbb2d); color: white;"
    >
      <div class="container">
        <h1 style="font-size: 3rem; margin-bottom: 20px;">
          Strategic Partnerships
        </h1>
        <p style="font-size: 1.2rem; max-width: 800px; margin: 0 auto;">
          Collaborating with the world's most innovative technology companies to
          empower businesses in the UAE and beyond.
        </p>
      </div>
    </section>

    <section class="partners-content" style="padding: 80px 0;">
      <div class="container">
        <div class="services-grid">
          <div class="service-card">
            <h3>
              <a
                href="https://www.microsoft.com"
                target="_blank"
                rel="noopener noreferrer"
              >
                Microsoft
              </a>
            </h3>

            <p>
              We customize and do custom implemenations of Microsoft Dynamics 365 ERP and CRM solutions to help 
              businesses optimize their operations and customer relationships, and add agentic workflows.
            </p>
            <small> Technology Partner • Cloud & Enterprise Solutions </small>
          </div>
          <div class="service-card">
            <h3>
              <a
                href="https://cloud.google.com/partners"
                target="_blank"
                rel="noopener noreferrer"
              >
                Google
              </a>
            </h3>
            <p>
              We work with Google's AI, Workspaces, Cloud resources, Firebase and App development frameworks to create 
              intelligent, collaborative, and data-driven applications that meet the evolving needs of our clients.
            </p>
            <small>Application Developer</small>
          </div>
          <div class="service-card">
            <h3>
              <a
                href="https://www.apple.com"
                target="_blank"
                rel="noopener noreferrer"
              >
                Apple
              </a>
            </h3>
            <p>
              Developing premium native iOS and macOS experiences, ensuring our mobile applications meet the 
              highest standards of performance and design.
            </p>
            <small>Application Developer</small>
          </div>
          <div class="service-card">
            <h3>
              <a
                href="https://www.cisco.com"
                target="_blank"
                rel="noopener noreferrer"
              >
                Cisco
              </a>
            </h3>

            <p>
              Integrating world-class networking and security hardware to provide our clients with reliable, 
              high-performance network designs and IoT infrastructure.
            </p>
            <small>Integrator Partner</small>
          </div>
          <div class="service-card">
            <h3>
              <a
                href="https://www.oracle.com"
                target="_blank"
                rel="noopener noreferrer"
              >
                Oracle
              </a>
            </h3>

            <p>
              Building data-intensive applications backed by Oracle's industry-leading database management systems and 
              cloud ERP solutions.
            </p>
            <small>Member</small>
          </div>
      </div>
    </section>

    <section
      class="cta"
      style="padding: 60px 0; background: #f8f9fa; text-align: center;"
    >
      <div class="container">
        <h2>Ready to build with the best?</h2>
        <p>
          Contact us today to discuss how our partnerships can benefit your next
          project.
        </p>
        <a
          href="/contact/"
          class="btn"
          style="display: inline-block; margin-top: 20px; padding: 12px 30px; background: #2563eb; color: white; text-decoration: none; border-radius: 5px;"
          >Work With Us</a
        >
      </div>
    </section>
  </main>
</Layout>
