---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="اتصل بنا | جنرال سوفت الإمارات"
  description="تواصل مع جنرال سوفت لتطوير البرمجيات المخصصة وتطبيقات الهاتف المحمول وإنترنت الأشياء وحلول الذكاء الاصطناعي في الإمارات."
  path="/contact/"
  isArabic={true}
>
  <header>
    <nav>
      <div class="logo">
        <img width="48" src="/img/logo.webp" alt="شعار جنرال سوفت"/>
        <span class="logo-text">Generalsoft<span class="logo-legal">FZ-LLC</span></span>
      </div>
      <span class="lang-switch"><a href="/contact/">English</a></span>
      <ul class="nav-links">
        <li><a href="/ar/">الرئيسية</a></li>
        <li class="dropdown">
          <a href="#services" class="dropbtn">الخدمات</a>
          <div class="dropdown-content">
            <a href="/ar/services/custom-software/">تطوير البرمجيات المخصصة</a>
            <a href="/ar/services/education-training/">التعليم والتدريب</a>
            <a href="/ar/services/ai-development/">تطوير الذكاء الاصطناعي</a>
            <a href="/ar/services/systems-design/">تصميم الأنظمة والبرمجيات</a>
            <a href="/ar/services/cyber-security/">الأمن السيبراني</a>
            <a href="/ar/services/web-design/">تصميم الشبكات والمواقع</a>
            <a href="/ar/services/mobile-apps/">تطبيقات التعلم المحمولة</a>
            <a href="/ar/services/electronic-systems/">الأنظمة الإلكترونية</a>
          </div>
        </li>
        <li><a href="/ar/contact/">اتصل بنا</a></li>
        <li><a href="/ar/#about">من نحن</a></li>
      </ul>
    </nav>
  </header>

  <section class="contact-page-hero">
    <div class="container">
      <h1>تواصل معنا</h1>
      <p>يسعدنا التواصل معك. دعنا نناقش كيف يمكننا المساعدة في تحويل أعمالك.</p>
    </div>
  </section>

  <section class="contact-page-content">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-container">
          <h2>أرسل لنا رسالة</h2>
          <form id="contactForm" class="contact-form" method="POST" action="https://formsubmit.co/info@generalsoft.ae">
            <!-- FormSubmit Configuration -->
            <input type="hidden" name="_subject" value="نموذج اتصال جديد من جنرال سوفت">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_template" value="table">

            <div class="form-group">
              <label for="name">الاسم الكامل *</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">البريد الإلكتروني *</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="phone">رقم الهاتف</label>
              <input type="tel" id="phone" name="phone">
            </div>

            <div class="form-group">
              <label for="company">اسم الشركة</label>
              <input type="text" id="company" name="company">
            </div>

            <div class="form-group">
              <label for="service">الخدمة المطلوبة</label>
              <select id="service" name="service">
                <option value="">اختر خدمة</option>
                <option value="تطوير البرمجيات المخصصة">تطوير البرمجيات المخصصة</option>
                <option value="التعليم والتدريب">التعليم والتدريب</option>
                <option value="تطوير الذكاء الاصطناعي">تطوير الذكاء الاصطناعي</option>
                <option value="تصميم الأنظمة والبرمجيات">تصميم الأنظمة والبرمجيات</option>
                <option value="الأمن السيبراني">الأمن السيبراني</option>
                <option value="تصميم الشبكات والمواقع">تصميم الشبكات والمواقع</option>
                <option value="تطبيقات المحمول">تطبيقات المحمول</option>
                <option value="الأنظمة الإلكترونية">الأنظمة الإلكترونية</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">الرسالة *</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>

            <button type="submit" class="submit-btn">إرسال الرسالة</button>
            <div id="formMessage" class="form-message"></div>
          </form>
        </div>

        <div class="contact-info-container">
          <h2>معلومات الاتصال</h2>

          <div class="info-item">
            <div class="info-icon">📧</div>
            <div class="info-content">
              <h3>البريد الإلكتروني</h3>
              <p>info@generalsoft.ae</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📞</div>
            <div class="info-content">
              <h3>الهاتف</h3>
              <p>+971.55.880.9863</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📍</div>
            <div class="info-content">
              <h3>العنوان</h3>
              <p>المنطقة الاقتصادية برأس الخيمة (RAKEZ)<br>رأس الخيمة، الإمارات العربية المتحدة</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">🕐</div>
            <div class="info-content">
              <h3>ساعات العمل</h3>
              <p>الأحد - الخميس: 9:00 صباحاً - 6:00 مساءً<br>الجمعة - السبت: مغلق</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
