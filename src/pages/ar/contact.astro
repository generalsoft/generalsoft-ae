---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="اتصل بشركة جنرال سوفت FZ-LLC | شركة برمجيات في دبي، الإمارات"
  description="تواصل مع شركة جنرال سوفت FZ-LLC في دبي، الإمارات لتطوير البرمجيات وحلول الذكاء الاصطناعي وخدمات تقنية المعلومات. اتصل أو أرسل بريداً إلكترونياً أو زرنا."
  path="/contact/"
  isArabic={true}
  image="/img/og-contact.jpg"
>

  <section class="contact-page-content">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-container">
          <h2>أرسل لنا رسالة</h2>
          <form id="contactForm" class="contact-form" novalidate>
            <div class="form-group">
              <label for="name">الاسم الكامل *</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">البريد الإلكتروني *</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="phone">رقم الهاتف</label>
              <input type="tel" id="phone" name="phone">
            </div>

            <div class="form-group">
              <label for="company">اسم الشركة</label>
              <input type="text" id="company" name="company">
            </div>

            <div class="form-group">
              <label for="service">الخدمة المطلوبة</label>
              <select id="service" name="service">
                <option value="">اختر خدمة</option>
                <option value="تطوير البرمجيات المخصصة">تطوير البرمجيات المخصصة</option>
                <option value="التعليم والتدريب">التعليم والتدريب</option>
                <option value="تطوير الذكاء الاصطناعي">تطوير الذكاء الاصطناعي</option>
                <option value="تصميم الأنظمة والبرمجيات">تصميم الأنظمة والبرمجيات</option>
                <option value="الأمن السيبراني">الأمن السيبراني</option>
                <option value="تصميم الشبكات والمواقع">تصميم الشبكات والمواقع</option>
                <option value="تطبيقات المحمول">تطبيقات المحمول</option>
                <option value="الأنظمة الإلكترونية">الأنظمة الإلكترونية</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">الرسالة *</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>

            <button type="submit" class="submit-btn">إرسال الرسالة</button>
            <div id="formMessage" class="form-message"></div>
          </form>
        </div>

        <div class="contact-info-container">
          <h2>معلومات الاتصال</h2>

          <div class="info-item">
            <div class="info-icon">📧</div>
            <div class="info-content">
              <h3>البريد الإلكتروني</h3>
              <p>info@generalsoft.ae</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📞</div>
            <div class="info-content">
              <h3>الهاتف</h3>
              <p>+971.55.880.9863</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📍</div>
            <div class="info-content">
              <h3>العنوان</h3>
              <p>المنطقة الاقتصادية برأس الخيمة (RAKEZ)<br>رأس الخيمة، الإمارات العربية المتحدة</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">🕐</div>
            <div class="info-content">
              <h3>ساعات العمل</h3>
              <p>الأحد - الخميس: 9:00 صباحاً - 6:00 مساءً<br>الجمعة - السبت: مغلق</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initContactForm } from '../../js/firebase-contact.js';
    initContactForm('contactForm', 'formMessage', {}, 'ar');
  </script>
</Layout>
