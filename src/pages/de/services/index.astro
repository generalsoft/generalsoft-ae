---
import Layout from '../../../layouts/Layout.astro';
---

<Layout 
  title="Unsere Dienstleistungen | Generalsoft VAE"
  description="Experten für Individualsoftware, mobile Apps und IoT-Systemdesign in RAKEZ. Transformieren Sie Ihr Geschäft mit innovativen Engineering-Lösungen."
  path="/de/services/"
  image="/img/og-home.jpg"
>
  <main>
    <section class="service-content">
      <div class="container">
        <h1 class="service-title">Unsere Expertise</h1>
        <p>Wir bieten ein breites Spektrum an technischen Dienstleistungen an, um Ihr Unternehmen im digitalen Zeitalter voranzubringen.</p>
        
        <div class="services-grid">
          <div class="service-card">
            <h3>Individualsoftware</h3>
            <p>Maßgeschneiderte Lösungen für komplexe Geschäftsanforderungen.</p>
            <a href="/de/services/custom-software/" class="cta-link">Mehr erfahren →</a>
          </div>
          
          <div class="service-card">
            <h3>KI-Entwicklung</h3>
            <p>Intelligente Automatisierung und Machine Learning Integration.</p>
            <a href="/de/services/ai-development/" class="cta-link">Mehr erfahren →</a>
          </div>

          <div class="service-card">
            <h3>Cybersicherheit</h3>
            <p>Schutz Ihrer digitalen Assets durch modernste Sicherheitsprotokolle.</p>
            <a href="/de/services/cyber-security/" class="cta-link">Mehr erfahren →</a>
          </div>

          <div class="service-card">
            <h3>IoT & Elektronik</h3>
            <p>Vernetzte Systeme und intelligente Hardware-Lösungen.</p>
            <a href="/de/services/electronic-systems/" class="cta-link">Mehr erfahren →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>