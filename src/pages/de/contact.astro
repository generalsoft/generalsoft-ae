---
import Layout from '../../layouts/Layout.astro';
---
<Layout 
  title="Kontakt Generalsoft FZ-LLC | Softwareunternehmen in RAKEZ, VAE"
  description="Kontaktieren Sie Generalsoft FZ-LLC in RAKEZ, VAE für Softwareentwicklung, KI-Lösungen und IT-Dienstleistungen. Rufen Sie uns an, schreiben Sie eine E-Mail oder besuchen Sie uns."
  path="/de/contact/"
  image="/img/og-contact.jpg"
>

  <section class="contact-page-content">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-container">
          <h2>Schreiben Sie uns eine Nachricht</h2>
          <form id="contactForm" class="contact-form" novalidate>
            <div class="form-group">
              <label for="name">Vollständiger Name *</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">E-Mail-Adresse *</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="phone">Telefonnummer</label>
              <input type="tel" id="phone" name="phone">
            </div>

            <div class="form-group">
              <label for="company">Firmenname</label>
              <input type="text" id="company" name="company">
            </div>

            <div class="form-group">
              <label for="service">Gewünschte Dienstleistung</label>
              <select id="service" name="service">
                <option value="">Dienstleistung auswählen</option>
                <option value="Individualsoftware-Entwicklung">Individualsoftware-Entwicklung</option>
                <option value="Ausbildung & Training">Ausbildung & Training</option>
                <option value="KI-Entwicklung">KI-Entwicklung</option>
                <option value="System- & Softwaredesign">System- & Softwaredesign</option>
                <option value="Cybersicherheit">Cybersicherheit</option>
                <option value="Web- & Netzwerkdesign">Web- & Netzwerkdesign</option>
                <option value="Mobile Anwendungen">Mobile Anwendungen</option>
                <option value="Elektronische Systeme">Elektronische Systeme</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Nachricht *</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>

            <button type="submit" class="submit-btn">Nachricht senden</button>
            <div id="formMessage" class="form-message"></div>
          </form>
        </div>

        <div class="contact-info-container">
          <h2>Kontaktinformationen</h2>

          <div class="info-item">
            <div class="info-icon">📧</div>
            <div class="info-content">
              <h3>Email</h3>
              <p>info@generalsoft.ae</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📞</div>
            <div class="info-content">
              <h3>Telefon</h3>
              <p>+971.55.880.9863</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">📍</div>
            <div class="info-content">
              <h3>Adresse</h3>
              <p>Ras Al Khaimah Economic Zone (RAKEZ)<br>Ras Al Khaimah, United Arab Emirates</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon">🕐</div>
            <div class="info-content">
              <h3>Geschäftszeiten</h3>
              <p>Sonntag - Donnerstag: 09:00 - 18:00 Uhr<br>Freitag - Samstag: Geschlossen</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="module" src="/js/contact-form-de.js"></script>
</Layout>
