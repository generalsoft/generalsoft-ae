---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-banner.png'; 
---

<Layout 
  title="Generalsoft | Custom Software & Web Development UAE"
  description="Expert custom software solutions, mobile app development, and IoT systems design in Dubai. Transform your business with GeneralSoft's innovative engineering."
  path="/"
>
  <main>
    <section class="hero-carousel">
      <div class="hero-carousel-container">
        <div class="hero-carousel-track">
          <!-- Hero Banner Slide -->
          <div class="hero-carousel-slide active">
            <div class="hero-carousel-image">
              <Image 
                src={heroImage} 
                alt="Transforming businesses with custom software" 
                loading="eager"
                fetchpriority="high"
                width={1200}
                height={600}
              />
            </div>
            <div class="hero-carousel-overlay">
              <h1>Custom Software Solutions for Global Businesses</h1>
              <p>We build scalable, high-performance applications tailored to your specific needs.</p>
            </div>
          </div>

          <!-- Custom Software Development -->
          <div class="hero-carousel-slide" data-href="/services/custom-software/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#csd-grad-1)"/>

                <defs><linearGradient id="csd-grad-1" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#7c3aed"/></linearGradient></defs>

                <rect x="60" y="50" width="280" height="40" rx="6" fill="rgba(255,255,255,0.2)"/>
                <rect x="60" y="110" width="200" height="12" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="60" y="135" width="240" height="12" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="60" y="160" width="180" height="12" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="60" y="200" width="120" height="36" rx="8" fill="rgba(255,255,255,0.25)"/>
                <circle cx="320" cy="200" r="40" fill="rgba(255,255,255,0.1)"/>
                <path d="M305 200l10 10 20-20" stroke="rgba(255,255,255,0.4)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Custom Software Development</h2>
              <p>Enterprise-grade custom software solutions that drive digital transformation and business growth.</p>
            </div>
          </div>

          <!-- Education & Training -->
          <div class="hero-carousel-slide" data-href="/services/education-training/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#edu-grad-2)"/>

                <defs><linearGradient id="edu-grad-2" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#059669"/><stop offset="100%" stop-color="#2563eb"/></linearGradient></defs>

                <rect x="100" y="60" width="200" height="30" rx="6" fill="rgba(255,255,255,0.2)"/>
                <rect x="120" y="105" width="160" height="8" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="120" y="125" width="160" height="8" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="120" y="145" width="160" height="8" rx="4" fill="rgba(255,255,255,0.15)"/>
                <circle cx="200" cy="210" r="35" fill="rgba(255,255,255,0.1)"/>
                <path d="M200 195v30M185 210h30" stroke="rgba(255,255,255,0.4)" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Education & Training</h2>
              <p>Comprehensive education and training programs designed to upskill your workforce with the latest technology expertise.</p>
            </div>
          </div>

          <!-- AI Development -->
          <div class="hero-carousel-slide" data-href="/services/ai-development/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#ai-grad-3)"/>

                <defs><linearGradient id="ai-grad-3" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#dc2626"/><stop offset="100%" stop-color="#7c3aed"/></linearGradient></defs>

                <circle cx="200" cy="100" r="45" fill="rgba(255,255,255,0.1)"/>
                <circle cx="200" cy="100" r="25" fill="rgba(255,255,255,0.15)"/>
                <circle cx="200" cy="100" r="10" fill="rgba(255,255,255,0.25)"/>
                <line x1="200" y1="145" x2="200" y2="180" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                <circle cx="170" cy="200" r="8" fill="rgba(255,255,255,0.15)"/>
                <circle cx="200" cy="210" r="8" fill="rgba(255,255,255,0.15)"/>
                <circle cx="230" cy="200" r="8" fill="rgba(255,255,255,0.15)"/>
                <line x1="170" y1="200" x2="200" y2="210" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
                <line x1="200" y1="210" x2="230" y2="200" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>AI Development</h2>
              <p>Harness the power of machine learning, deep learning, and intelligent automation to transform your business operations.</p>
            </div>
          </div>

          <!-- Systems & Software Design -->
          <div class="hero-carousel-slide" data-href="/services/systems-design/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#sys-grad-4)"/>

                <defs><linearGradient id="sys-grad-4" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#0891b2"/><stop offset="100%" stop-color="#059669"/></linearGradient></defs>

                <rect x="80" y="60" width="240" height="160" rx="8" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                <rect x="100" y="80" width="80" height="50" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="200" y="80" width="100" height="50" rx="4" fill="rgba(255,255,255,0.15)"/>
                <rect x="100" y="145" width="200" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="100" y="162" width="160" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="100" y="179" width="180" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="80" y="235" width="240" height="3" rx="2" fill="rgba(255,255,255,0.15)"/>
                <circle cx="100" cy="236.5" r="5" fill="rgba(255,255,255,0.3)"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Systems & Software Design</h2>
              <p>Expert systems architecture and software design services that ensure your digital infrastructure is robust and scalable.</p>
            </div>
          </div>

          <!-- Cyber Security -->
          <div class="hero-carousel-slide" data-href="/services/cyber-security/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#cyber-grad-5)"/>

                <defs><linearGradient id="cyber-grad-5" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#1e293b"/><stop offset="100%" stop-color="#dc2626"/></linearGradient></defs>

                <path d="M200 60l100 50v60c0 50-43 80-100 100-57-20-100-50-100-100v-60l100-50z" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.25)" stroke-width="2"/>
                <path d="M175 150l20 20 35-40" stroke="rgba(255,255,255,0.5)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="150" y="110" width="100" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="160" y="128" width="80" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Cyber Security</h2>
              <p>Protect your business with comprehensive cyber security solutions including threat detection and security architecture design.</p>
            </div>
          </div>

          <!-- Web & Network Design -->
          <div class="hero-carousel-slide" data-href="/services/web-design/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#web-grad-6)"/>

                <defs><linearGradient id="web-grad-6" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#06b6d4"/></linearGradient></defs>

                <circle cx="200" cy="120" r="60" fill="rgba(255,255,255,0.1)"/>
                <circle cx="200" cy="120" r="40" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
                <circle cx="200" cy="120" r="20" fill="rgba(255,255,255,0.1)"/>
                <line x1="200" y1="60" x2="200" y2="180" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
                <line x1="140" y1="120" x2="260" y2="120" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
                <rect x="100" y="210" width="200" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="130" y="228" width="140" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="150" y="246" width="100" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Web & Network Design</h2>
              <p>Professional web development and network design services that deliver exceptional user experiences and reliable, high-performance connectivity.</p>
            </div>
          </div>

          <!-- Mobile Applications -->
          <div class="hero-carousel-slide" data-href="/services/mobile-apps/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#mobile-grad-7)"/>

                <defs><linearGradient id="mobile-grad-7" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#7c3aed"/><stop offset="100%" stop-color="#dc2626"/></linearGradient></defs>

                <rect x="155" y="50" width="90" height="180" rx="12" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                <circle cx="200" cy="80" r="5" fill="rgba(255,255,255,0.3)"/>
                <rect x="167" y="100" width="66" height="90" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="175" y="110" width="50" height="6" rx="3" fill="rgba(255,255,255,0.15)"/>
                <rect x="175" y="125" width="40" height="6" rx="3" fill="rgba(255,255,255,0.15)"/>
                <rect x="175" y="140" width="45" height="6" rx="3" fill="rgba(255,255,255,0.15)"/>
                <rect x="175" y="155" width="35" height="6" rx="3" fill="rgba(255,255,255,0.15)"/>
                <rect x="175" y="170" width="50" height="6" rx="3" fill="rgba(255,255,255,0.15)"/>
                <rect x="185" y="210" width="30" height="4" rx="2" fill="rgba(255,255,255,0.2)"/>
                <rect x="100" y="245" width="200" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="130" y="263" width="140" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Mobile Applications</h2>
              <p>Native and cross-platform mobile applications built with modern frameworks like Flutter and React Native, delivering premium user experiences.</p>
            </div>
          </div>

          <!-- Electronic Systems -->
          <div class="hero-carousel-slide" data-href="/services/electronic-systems/">
            <div class="hero-carousel-image">
              <svg viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="400" height="300" fill="url(#elec-grad-8)"/>

                <defs><linearGradient id="elec-grad-8" x1="0" y1="0" x2="400" y2="300"><stop offset="0%" stop-color="#059669"/><stop offset="100%" stop-color="#0891b2"/></linearGradient></defs>

                <rect x="100" y="70" width="200" height="120" rx="8" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
                <circle cx="140" cy="130" r="15" fill="rgba(255,255,255,0.15)"/>
                <circle cx="200" cy="130" r="15" fill="rgba(255,255,255,0.15)"/>
                <circle cx="260" cy="130" r="15" fill="rgba(255,255,255,0.15)"/>
                <circle cx="140" cy="130" r="5" fill="rgba(255,255,255,0.3)"/>
                <circle cx="200" cy="130" r="5" fill="rgba(255,255,255,0.3)"/>
                <circle cx="260" cy="130" r="5" fill="rgba(255,255,255,0.3)"/>
                <line x1="155" y1="130" x2="185" y2="130" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
                <line x1="215" y1="130" x2="245" y2="130" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
                <path d="M200 70v-10M200 190v10" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                <rect x="130" y="215" width="140" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
                <rect x="150" y="233" width="100" height="8" rx="4" fill="rgba(255,255,255,0.12)"/>
              </svg>
            </div>
            <div class="hero-carousel-overlay">
              <h2>Electronic Systems</h2>
              <p>Robust IoT architectures and electronic systems for smart monitoring, automated industrial systems, and consumer electronics with real-time data flow.</p>
            </div>
          </div>
        </div>

        <div class="hero-carousel-nav">
          <button class="hero-carousel-btn hero-carousel-prev" aria-label="Previous slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="hero-carousel-dots"></div>
          <button class="hero-carousel-btn hero-carousel-next" aria-label="Next slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
    </section>

    <section class="about-detailed">

      <h2>Comprehensive Software Engineering in the UAE</h2>
      <p>
        At GeneralSoft, we specialize in bridging the gap between complex business challenges and 
        elegant technical solutions. Our expertise spans across Systems Design, Mobile App Development, 
        and Electronic Systems (IoT). By leveraging modern architectures, we ensure that your 
        digital infrastructure is not only robust for today but scalable for tomorrow's growth.
      </p>
    </section>


    <section class="services-detailed">
      <div class="container">
        <h2>Our Core Specializations</h2>
        <div class="services-grid">
          <div class="service-card">
            <h3>Custom Software Development</h3>
            <p>We build bespoke software solutions designed to streamline your unique business workflows. From enterprise resource planning (ERP) to customer relationship management (CRM), our engineering team focuses on security, scalability, and seamless integration with your existing legacy systems.</p>
          </div>
          <div class="service-card">
            <h3>Mobile Application Engineering</h3>
            <p>Our mobile solutions span native iOS and Android development using modern frameworks like Flutter and React Native. we ensure your brand delivers a premium user experience with high-performance interfaces and offline-first capabilities.</p>
          </div>
          <div class="service-card">
            <h3>IoT & Electronic Systems</h3>
            <p>GeneralSoft bridges the gap between hardware and software. We design robust IoT architectures for smart monitoring, automated industrial systems, and consumer electronics, ensuring real-time data flow and reliable connectivity.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="process">
      <div class="container">
        <h2>Our Development Process</h2>
        <p>Our methodology is rooted in the Agile philosophy, ensuring transparency and rapid delivery. We begin with a deep discovery phase to understand your technical requirements, followed by iterative development sprints, rigorous QA testing, and automated CI/CD deployment pipelines.</p>
        <ul>
          <li><strong>Discovery & Strategy:</strong> Aligning business goals with technical feasibility.</li>
          <li><strong>Architecture Design:</strong> Blueprinting scalable system structures.</li>
          <li><strong>Development:</strong> Clean, documented code following industry best practices.</li>
          <li><strong>Deployment & Support:</strong> Seamless go-live and ongoing maintenance.</li>
        </ul>
      </div>
    </section>

    <section class="tech-stack">
      <div class="container">
        <h2>Cutting-Edge Tech Stack</h2>
        <p>We leverage a modern tech stack to build future-proof solutions, including <strong>Node.js</strong>, <strong>Astro</strong>, <strong>React</strong>, <strong>Python</strong> for AI/ML, and <strong>AWS/Azure</strong> for cloud infrastructure. This ensures your project benefits from the latest security patches and performance optimizations available in the ecosystem.</p>
      </div>
    </section>
  </main>
</Layout>
