---
import Layout from '../../layouts/Layout.astro';

const currentPath = Astro.url.pathname;
const currentLocale = currentPath.match(/^\/(en|ar|de)(?=\/|$)/)?.[1] || 'en';
const prefix = `/${currentLocale}`;
---


<Layout
  title="About Us | Generalsoft UAE"
  description="Learn about Generalsoft, a premier software engineering firm in the UAE. We specialize in custom software development, systems architecture, and innovative IoT solutions."
  path="/about/"
  image="/img/og-about.jpg"
>
  <main>
    <section
      class="page-header"
      style="padding: 100px 0 50px; text-align: center; background: linear-gradient(135deg, #1e293b, #2563eb); color: white;"
    >
      <div class="container">
        <h1 style="font-size: 3rem; margin-bottom: 20px;">Our Story</h1>
        <p style="font-size: 1.2rem; max-width: 800px; margin: 0 auto;">
          Driving digital excellence across the United Arab Emirates through 
          disciplined engineering and innovative software design.
        </p>
      </div>
    </section>

    <section class="about-content" style="padding: 80px 0;">
      <div class="container">
        <div class="about-detailed">
          <h2>Who We Are</h2>
          <p>
            Generalsoft FZ-LLC is a boutique software engineering firm based in the UAE. 
            We were founded on the principle that high-quality software is the backbone 
            of modern business growth. Our team of experts specializes in transforming 
            complex requirements into scalable, secure, and user-centric digital products.
          </p>
          
          <div class="services-grid" style="margin-top: 40px;">
            <div class="service-card">
              <h3>Our Mission</h3>
              <p>To empower businesses in the Middle East with custom-built technology that solves real-world problems and creates sustainable competitive advantages.</p>
            </div>
            <div class="service-card">
              <h3>Our Vision</h3>
              <p>To be the most trusted technology partner in the UAE, recognized for our commitment to technical excellence and client success.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="values" style="padding: 80px 0; background: var(--bg-alt);">
      <div class="container">
        <h2 style="text-align: center; margin-bottom: 3rem;">Core Values</h2>
        <div class="services-grid">
          <div class="service-card">
            <h4>Innovation</h4>
            <p>We stay at the forefront of emerging technologies like AI and IoT to provide future-proof solutions.</p>
          </div>
          <div class="service-card">
            <h4>Reliability</h4>
            <p>Our engineering processes are rigorous, ensuring that the systems we build are stable and secure.</p>
          </div>
          <div class="service-card">
            <h4>Local Expertise</h4>
            <p>Based in the UAE, we understand the local market dynamics and regulatory requirements for digital products.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta" style="padding: 60px 0; background: #f8f9fa; text-align: center;">
      <div class="container">
        <div class="cta-content-with-qr">
          <div class="cta-text-group">
            <h2>Partner with Engineering Experts</h2>
            <p>
              Let's discuss how our team can help you achieve your digital goals.
            </p>
            <a href={`${prefix}/contact/`} class="cta-button" style="margin-top: 20px;">

              Get in Touch
            </a>
          </div>
          <div class="cta-qr-card">
            <h3>Digital vCard</h3>
            <img src="/img/generalsoft_qr_vcard.png" alt="Generalsoft vCard QR" width="120" style="margin: 0.5rem 0;" />
            <p>Scan this code with your phone camera to instantly save our contact details to your address book.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>