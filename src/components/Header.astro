---
interface Props {
  isArabic?: boolean;
}
const { isArabic } = Astro.props;
const currentPath = Astro.url.pathname;
const currentLocale = currentPath.match(/^\/(en|ar|de)(?=\/|$)/)?.[1] || 'en';
const prefix = `/${currentLocale}`;
const routePath = currentPath.replace(/^\/(?:en|ar|de)/, '') || '/';
const languages = [
  { code: 'en', label: 'English', flag: '🇺🇸' },
  { code: 'ar', label: 'العربية', flag: '🇦🇪' },
  { code: 'de', label: 'Deutsch', flag: '🇩🇪' },
];

const t = {
  en: {
    home: 'Home',
    services: 'Services',
    partners: 'Partners',
    contact: 'Contact Us',
    about: 'About Us',
    csd: 'Custom Software Development',
    edu: 'Education & Training',
    ai: 'AI Development',
    sys: 'Systems & Software Design',
    cyber: 'Cyber Security',
    web: 'Web & Network Design',
    mobile: 'Mobile Applications',
    elec: 'Electronic Systems',
    logo: 'Generalsoft',
    legal: 'FZ-LLC'
  },
  ar: {
    home: 'الرئيسية',
    services: 'خدماتنا',
    partners: 'الشركاء',
    contact: 'اتصل بنا',
    about: 'من نحن',
    csd: 'تطوير البرمجيات المخصصة',
    edu: 'التعليم والتدريب',
    ai: 'تطوير الذكاء الاصطناعي',
    sys: 'تصميم الأنظمة والبرمجيات',
    cyber: 'الأمن السيبراني',
    web: 'تصميم الشبكات والمواقع',
    mobile: 'تطبيقات الجوال',
    elec: 'الأنظمة الإلكترونية',
    logo: 'جنرال سوفت',
    legal: 'ش.م.ح – ذ.م.م'
  },
  de: {
    home: 'Startseite',
    services: 'Services',
    partners: 'Partner',
    contact: 'Kontakt',
    about: 'Über uns',
    csd: 'Individualsoftware',
    edu: 'Ausbildung & Training',
    ai: 'KI-Entwicklung',
    sys: 'System- & Softwaredesign',
    cyber: 'Cybersicherheit',
    web: 'Web- & Netzwerkdesign',
    mobile: 'Mobile Apps',
    elec: 'Elektronische Systeme',
    logo: 'Generalsoft',
    legal: 'FZ-LLC'
  }
};

const labels = (t as any)[currentLocale] || t.en;
const currentLanguage = languages.find((lang) => lang.code === currentLocale) ?? languages[0];
---
<header>
  <nav>
    <a href={`${prefix}/`} class="logo">
      <img width="48" src="/img/logo.webp" alt="GeneralSoft Logo"/>
      <span class="logo-text">{labels.logo}<span class="logo-legal">{labels.legal}</span></span>
    </a>
    <div class="lang-switch">
      <button class="lang-btn" type="button" aria-haspopup="true" aria-expanded="false">
        <span class="lang-btn-inner">
          <span class="flag-icon">{currentLanguage.flag}</span>
          <span class="lang-label">{currentLanguage.label}</span>
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </span>
      </button>
      <div class="lang-dropdown">
        {languages.map(lang => (
          <a 
            class={`lang-option${currentLocale === lang.code ? ' active' : ''}`} 
            href={`/${lang.code}${routePath === '/' ? '/' : routePath}`}
          >
            <span class="lang-option-flag">{lang.flag}</span>
            <span class="lang-option-label">{lang.label}</span>
            {currentLocale === lang.code && (
              <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <ul class="nav-links">
      <li><a href={`${prefix}/`}>{labels.home}</a></li>
      <li class="dropdown">
        <a href={`${prefix}/#services`} class="dropbtn">{labels.services} <span class="dropdown-arrow">▼</span></a>
        <div class="dropdown-content">
          <a href={`${prefix}/services/custom-software/`}>{labels.csd}</a>
          <a href={`${prefix}/services/education-training/`}>{labels.edu}</a>
          <a href={`${prefix}/services/ai-development/`}>{labels.ai}</a>
          <a href={`${prefix}/services/systems-design/`}>{labels.sys}</a>
          <a href={`${prefix}/services/cyber-security/`}>{labels.cyber}</a>
          <a href={`${prefix}/services/web-design/`}>{labels.web}</a>
          <a href={`${prefix}/services/mobile-apps/`}>{labels.mobile}</a>
          <a href={`${prefix}/services/electronic-systems/`}>{labels.elec}</a>
        </div>
      </li>
      <li><a href={`${prefix}/partners/`}>{labels.partners}</a></li>
      <li><a href={`${prefix}/contact/`}>{labels.contact}</a></li>
      <li><a href={`${prefix}/about/`}>{labels.about}</a></li>
    </ul>
  </nav>
</header>